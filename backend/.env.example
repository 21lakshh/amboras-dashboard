PORT=4000
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=https://your-project-ref.supabase.co
DATABASE_URL=postgresql://postgres:your-password@your-host:5432/postgres
REDIS_URL=redis://127.0.0.1:6379
ANALYTICS_INGEST_API_KEY=replace-with-a-strong-secret
ANALYTICS_BATCH_INTERVAL_MS=2000
ANALYTICS_BATCH_SIZE=1000
AUTH_STORE_CONTEXT_TTL_SECONDS=900

# Optional test load-script defaults
ANALYTICS_BASE_URL=http://localhost:4000
SUPABASE_USER_ID=your-supabase-user-uuid
STORE_ID=your-store-id
STORE_IDS=store-a,store-b,store-c
ANALYTICS_STORE_COUNT=25
ANALYTICS_RATE_PER_MINUTE=10000
ANALYTICS_DURATION_SECONDS=60
ANALYTICS_CONCURRENCY=100
ANALYTICS_SEED_STORES=false
